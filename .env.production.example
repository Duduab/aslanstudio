# Copy this file on the VPS to `.env.production` in the same folder as
# `package.json`, then adjust values. Next.js loads `.env.production`
# automatically for `next build` and `next start`.
#
#     cp .env.production.example .env.production && nano .env.production
#
# Do not commit real `.env.production` secrets to Git.

# --- App URL (optional; set if you use absolute URLs in server code) ---
# NEXTAUTH_URL is only if you add NextAuth later
# NEXTAUTH_URL=https://YOUR_DOMAIN.com

# --- Booking API (Resend) — see src/app/api/booking/route.ts ---
# If unset, booking email sending is skipped / uses code defaults where documented.
RESEND_API_KEY=

# “From” address must be a verified domain/sender in Resend
BOOKING_FROM_EMAIL=Studio Rent <onboarding@resend.dev>

# Inbox that receives studio notifications for new bookings
BOOKING_NOTIFY_EMAIL=aslanstudiobs@gmail.com

# --- Node ---
NODE_ENV=production
