# =============================================================================
# Production environment template — studio-booking / Next.js
# =============================================================================
# Copy on the VPS to `.env.production` (recommended for `next build` / `next start`):
#   cp .env.example .env.production
# Then fill values. Do not commit `.env.production` with real secrets.
#
# Keys below cover common production stacks. Remove sections you do not use.
# This repo currently reads Resend/booking vars in API routes; others are placeholders.
# =============================================================================

NODE_ENV=production

# --- Next.js public (exposed to the browser; no secrets) ---
# NEXT_PUBLIC_APP_URL=https://YOUR_DOMAIN.com
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Stripe (server) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Google APIs (Calendar, Maps, OAuth, etc.) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_API_KEY=

# --- Database (Prisma / Drizzle / etc. — adjust name to your ORM) ---
# DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/studio_booking?schema=public

# --- NextAuth (if you add authentication) ---
# NEXTAUTH_URL=https://YOUR_DOMAIN.com
# NEXTAUTH_SECRET=  # generate: openssl rand -base64 32

# --- Email / booking API (used today in src/app/api/booking/route.ts) ---
RESEND_API_KEY=
BOOKING_FROM_EMAIL=Studio Rent <onboarding@resend.dev>
BOOKING_NOTIFY_EMAIL=your-studio-inbox@example.com
